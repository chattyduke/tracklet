# tracklet — generated / environment artifacts (never committed)
.venv/
out/
# the M1 real-image run output dir (README documents `--out out_real`); generated, never committed
out_real/
indexes/
astap/
*.fits
*.fits.fz
# real-frame fetch scratch (fetch.sh streams these on demand; never commit the bytes)
tests/fixtures/real/offset_*
tests/fixtures/real/fetch_stream.err
tests/fixtures/real/_derive_offset.py

# Python
__pycache__/
*.py[cod]
*.egg-info/
# wheel/sdist build artifacts (regenerated by `make build`; never committed — footprint discipline)
dist/
build/
.pytest_cache/
.mypy_cache/

# OS
.DS_Store

# NOTE: .tracklet/ IS tracked — it holds loop_state.md, the build loop's only memory.
